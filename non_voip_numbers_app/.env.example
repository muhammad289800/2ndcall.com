# App runtime
NUMBER_APP_HOST=0.0.0.0
NUMBER_APP_PORT=5050
NUMBER_APP_DEBUG=false

# Flask session secret — set a strong random string, required for stable sessions across restarts
SECRET_KEY=

# Admin token — protects the dashboard. Leave empty to allow unauthenticated access (dev only)
ADMIN_TOKEN=

# Optional custom db path
# NUMBER_APP_DB_PATH=/workspace/non_voip_numbers_app/non_voip_numbers.db

# Optional app webhook behavior
TWILIO_INBOUND_SAY_TEXT=Thanks for calling. Your call was received by 2ndCall.

# Telnyx (primary provider)
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_MESSAGING_PROFILE_ID=
# Optional for Telnyx call-control
TELNYX_CALL_WEBHOOK_URL=

# Bitget Pay / Paydify (crypto wallet top-up)
BITGET_APP_ID=
BITGET_API_SECRET=
BITGET_CURRENCY=USDT

